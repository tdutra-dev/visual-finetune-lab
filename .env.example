# OpenAI
OPENAI_API_KEY=sk-...

# Azure Storage (checkpoints + raw images)
AZURE_STORAGE_ACCOUNT=your_account
AZURE_STORAGE_KEY=your_key
AZURE_CONTAINER_IMAGES=vfl-images
AZURE_CONTAINER_CHECKPOINTS=vfl-checkpoints

# MLflow (Databricks Community Edition or local)
MLFLOW_TRACKING_URI=http://localhost:5000
# For Databricks CE: MLFLOW_TRACKING_URI=databricks

# Model
BASE_MODEL_ID=microsoft/Phi-3.5-vision-instruct
LORA_RANK=16
LORA_ALPHA=32
TRAIN_BATCH_SIZE=4
NUM_EPOCHS=3

# Serving
MODEL_CHECKPOINT_PATH=./checkpoints/best
PORT=8000
